{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "watchPatterns": [
      "/backend/**",
      "/backend/dist/**",
      "/package.json",
      "/package-lock.json"
    ],
    "buildCommand": "npm run prisma:generate --workspace backend && npm run build --workspace backend"
  },
  "deploy": {
    "preDeployCommand": ["npm run prisma:deploy --workspace backend"],
    "startCommand": "npm run start:prod --workspace backend",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE"
  }
}
